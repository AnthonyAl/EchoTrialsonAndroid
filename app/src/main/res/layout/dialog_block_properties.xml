<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxWidth="400dp"
    android:maxHeight="300dp"
    android:foregroundGravity="fill_horizontal|fill">

    <ImageView
        android:id="@+id/background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        app:srcCompat="@drawable/ui_properties_window" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/body"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/contents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Dialog Title -->
            <TextView
                android:id="@+id/dialogTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/aclonica"
                android:gravity="center"
                android:text="Block Properties"
                android:textColor="#875120"
                android:textSize="14sp"
                android:textStyle="bold|italic"
                android:typeface="sans" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/groupIdTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/aclonica"
                    android:gravity="center"
                    android:text="Group ID"
                    android:textColor="#481F19"
                    android:textSize="12sp"
                    android:textStyle="bold|italic"
                    android:typeface="sans" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#4A93774F"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/groupDownButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="#00FFFFFF"
                        android:scaleType="centerInside"
                        android:src="@drawable/ui_back"
                        tools:src="@drawable/ui_back" />

                    <TextView
                        android:id="@+id/groupIdText"
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/aclonica"
                        android:text="0"
                        android:textAlignment="center"
                        android:textColor="#481F19"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:typeface="sans" />

                    <ImageButton
                        android:id="@+id/groupUpButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="#00FFFFFF"
                        android:scaleType="centerInside"
                        android:src="@drawable/ui_forward"
                        tools:src="@drawable/ui_forward" />

                </LinearLayout>
            </LinearLayout>

            <!-- Group ID Section -->

        </LinearLayout>

        <ImageButton
            android:id="@+id/confirmButton2"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="18dp"
            android:background="#00FFFFFF"
            android:scaleType="centerInside"
            android:src="@drawable/ui_confirm"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:src="@drawable/ui_confirm" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</RelativeLayout>