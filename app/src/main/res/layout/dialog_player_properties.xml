<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxWidth="600dp"
    android:maxHeight="800dp"
    android:foregroundGravity="fill_horizontal|fill">

    <ImageView
        android:id="@+id/background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        app:srcCompat="@drawable/ui_properties_window" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/body"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/contents"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:gravity="right"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.533">

            <!-- Object Type Header -->

            <TextView
                android:id="@+id/dialogTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/aclonica"
                android:gravity="center"
                android:text="Player Properties"
                android:textColor="#875120"
                android:textSize="14sp"
                android:textStyle="bold|italic"
                android:typeface="sans" />

            <!-- Position Section -->

            <ScrollView
                android:id="@+id/playerPropertiesSection"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="16dp"
                android:fadeScrollbars="false"
                android:scrollbars="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/sizeSection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/sizeTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:fontFamily="@font/aclonica"
                                android:text="Size"
                                android:textAlignment="center"
                                android:textColor="#481F19"
                                android:textSize="12sp"
                                android:textStyle="bold|italic"
                                android:typeface="sans" />

                            <LinearLayout
                                android:id="@+id/sizeSubSection"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginBottom="16dp"
                                android:background="#4A93774F"
                                android:backgroundTintMode="multiply"
                                android:orientation="horizontal">

                                <ImageButton
                                    android:id="@+id/sizeDownButton"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="#00FFFFFF"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ui_back"
                                    tools:src="@drawable/ui_back" />

                                <TextView
                                    android:id="@+id/sizeText"
                                    android:layout_width="38dp"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_vertical"
                                    android:fontFamily="@font/aclonica"
                                    android:lineSpacingExtra="8sp"
                                    android:text="48"
                                    android:textAlignment="center"
                                    android:textColor="#481F19"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:typeface="sans" />

                                <ImageButton
                                    android:id="@+id/sizeUpButton"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="#00FFFFFF"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ui_forward"
                                    tools:src="@drawable/ui_forward" />

                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/groupIdSection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/groupIdTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:fontFamily="@font/aclonica"
                                android:text="Group ID"
                                android:textAlignment="center"
                                android:textColor="#481F19"
                                android:textSize="12sp"
                                android:textStyle="bold|italic"
                                android:typeface="sans" />

                            <LinearLayout
                                android:id="@+id/groupIdSubSection"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginBottom="16dp"
                                android:background="#4A93774F"
                                android:orientation="horizontal">

                                <ImageButton
                                    android:id="@+id/groupDownButton"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="#00FFFFFF"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ui_back"
                                    tools:src="@drawable/ui_back" />

                                <TextView
                                    android:id="@+id/groupIdText"
                                    android:layout_width="38dp"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_vertical"
                                    android:fontFamily="@font/aclonica"
                                    android:lineSpacingExtra="8sp"
                                    android:text="0"
                                    android:textAlignment="center"
                                    android:textColor="#481F19"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:typeface="sans" />

                                <ImageButton
                                    android:id="@+id/groupUpButton"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="#00FFFFFF"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ui_forward"
                                    tools:src="@drawable/ui_forward" />

                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/physicsPropertiesSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/physicsPropertiesTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/aclonica"
                            android:text="Physics Properties"
                            android:textAlignment="center"
                            android:textColor="#875120"
                            android:textSize="11sp"
                            android:textStyle="bold|italic"
                            android:typeface="sans" />

                        <LinearLayout
                            android:id="@+id/physicsPropertiesSubSection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/heightSection"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="5"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/textView7"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:fontFamily="@font/aclonica"
                                    android:text="Height"
                                    android:textAlignment="center"
                                    android:textColor="#481F19"
                                    android:textSize="12sp"
                                    android:textStyle="bold|italic"
                                    android:typeface="sans" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:background="#4A93774F"
                                    android:orientation="horizontal">

                                    <ImageButton
                                        android:id="@+id/heightDownButton"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="#00FFFFFF"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ui_back"
                                        tools:src="@drawable/ui_back" />

                                    <TextView
                                        android:id="@+id/heightText"
                                        android:layout_width="38dp"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center_vertical"
                                        android:fadingEdge="horizontal"
                                        android:fadingEdgeLength="@android:dimen/dialog_min_width_major"
                                        android:fontFamily="@font/aclonica"
                                        android:lineSpacingExtra="8sp"
                                        android:text="1.0"
                                        android:textAlignment="center"
                                        android:textColor="#481F19"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:typeface="sans" />

                                    <ImageButton
                                        android:id="@+id/heightUpButton"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="#00FFFFFF"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ui_forward"
                                        tools:src="@drawable/ui_forward" />

                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/widthSection"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="5"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/widthTitle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:fontFamily="@font/aclonica"
                                    android:text="Width"
                                    android:textAlignment="center"
                                    android:textColor="#481F19"
                                    android:textSize="12sp"
                                    android:textStyle="bold|italic"
                                    android:typeface="sans" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:background="#4A93774F"
                                    android:orientation="horizontal">

                                    <ImageButton
                                        android:id="@+id/widthDownButton"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="#00FFFFFF"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ui_back"
                                        tools:src="@drawable/ui_back" />

                                    <TextView
                                        android:id="@+id/widthText"
                                        android:layout_width="38dp"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center_vertical"
                                        android:fadingEdge="horizontal"
                                        android:fadingEdgeLength="@android:dimen/dialog_min_width_major"
                                        android:fontFamily="@font/aclonica"
                                        android:lineSpacingExtra="8sp"
                                        android:text="1.0"
                                        android:textAlignment="center"
                                        android:textColor="#481F19"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:typeface="sans" />

                                    <ImageButton
                                        android:id="@+id/widthUpButton"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="#00FFFFFF"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ui_forward"
                                        tools:src="@drawable/ui_forward" />

                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/speedSection"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="5"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/TextView"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:fontFamily="@font/aclonica"
                                    android:text="Walk speed"
                                    android:textAlignment="center"
                                    android:textColor="#481F19"
                                    android:textSize="12sp"
                                    android:textStyle="bold|italic"
                                    android:typeface="sans" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:background="#4A93774F"
                                    android:orientation="horizontal">

                                    <ImageButton
                                        android:id="@+id/speedDownButton"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="#00FFFFFF"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ui_back"
                                        tools:src="@drawable/ui_back" />

                                    <TextView
                                        android:id="@+id/velXText"
                                        android:layout_width="38dp"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center_vertical"
                                        android:fadingEdge="horizontal"
                                        android:fadingEdgeLength="@android:dimen/dialog_min_width_major"
                                        android:fontFamily="@font/aclonica"
                                        android:lineSpacingExtra="8sp"
                                        android:text="20.0"
                                        android:textAlignment="center"
                                        android:textColor="#481F19"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:typeface="sans" />

                                    <ImageButton
                                        android:id="@+id/speedUpButton"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="#00FFFFFF"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ui_forward"
                                        tools:src="@drawable/ui_forward" />

                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/jumpSection"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="5"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/jumpTitle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:fontFamily="@font/aclonica"
                                    android:text="Jump force"
                                    android:textAlignment="center"
                                    android:textColor="#481F19"
                                    android:textSize="12sp"
                                    android:textStyle="bold|italic"
                                    android:typeface="sans" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:background="#4A93774F"
                                    android:orientation="horizontal">

                                    <ImageButton
                                        android:id="@+id/jumpDownButton"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="#00FFFFFF"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ui_back"
                                        tools:src="@drawable/ui_back" />

                                    <TextView
                                        android:id="@+id/velYText"
                                        android:layout_width="38dp"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center_vertical"
                                        android:fadingEdge="horizontal"
                                        android:fadingEdgeLength="@android:dimen/dialog_min_width_major"
                                        android:fontFamily="@font/aclonica"
                                        android:lineSpacingExtra="8sp"
                                        android:text="10.0"
                                        android:textAlignment="center"
                                        android:textColor="#481F19"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:typeface="sans" />

                                    <ImageButton
                                        android:id="@+id/jumpUpButton"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="#00FFFFFF"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ui_forward"
                                        tools:src="@drawable/ui_forward" />

                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/gravitySection"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="5"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/gravityTitle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:fontFamily="@font/aclonica"
                                    android:text="Gravity force"
                                    android:textAlignment="center"
                                    android:textColor="#481F19"
                                    android:textSize="12sp"
                                    android:textStyle="bold|italic"
                                    android:typeface="sans" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:background="#4A93774F"
                                    android:orientation="horizontal">

                                    <ImageButton
                                        android:id="@+id/gravityDownButton"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="#00FFFFFF"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ui_back"
                                        tools:src="@drawable/ui_back" />

                                    <TextView
                                        android:id="@+id/gravityText"
                                        android:layout_width="38dp"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center_vertical"
                                        android:fadingEdge="horizontal"
                                        android:fadingEdgeLength="@android:dimen/dialog_min_width_major"
                                        android:fontFamily="@font/aclonica"
                                        android:lineSpacingExtra="8sp"
                                        android:text="10.0"
                                        android:textAlignment="center"
                                        android:textColor="#481F19"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:typeface="sans" />

                                    <ImageButton
                                        android:id="@+id/gravityUpButton"
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="#00FFFFFF"
                                        android:scaleType="centerInside"
                                        android:src="@drawable/ui_forward"
                                        tools:src="@drawable/ui_forward" />

                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </ScrollView>

        </LinearLayout>

        <ImageButton
            android:id="@+id/confirmButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            android:background="#00FFFFFF"
            android:scaleType="centerInside"
            android:src="@drawable/ui_confirm"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:src="@drawable/ui_confirm" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</RelativeLayout>
