<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DFA95C"
    android:theme="@style/ThemeOverlay.EchoTrialsOnAndroid.FullscreenContainer"
    tools:context=".view.GameHostActivity">

    <!-- The primary full-screen view. This can be replaced with whatever view
         is needed to present your content, e.g. VideoView, SurfaceView,
         TextureView, etc. -->

    <!-- This FrameLayout insets its children based on system windows using
         android:fitsSystemWindows. -->

    <com.unipi.alexandris.android.echotrialsonandroid.view.GameComponent
        android:id="@+id/game"
        android:layout_width="match_parent"
        android:layout_height="match_parent" >

    </com.unipi.alexandris.android.echotrialsonandroid.view.GameComponent>

    <FrameLayout
        android:id="@+id/backgroundEffect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000">

    </FrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <TextView
            android:id="@+id/globalTimerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/showcg"
            android:text="TIME: --:-- "
            android:textAlignment="center"
            android:textColor="#481F19"
            android:typeface="normal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/pauseButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:background="#00FFFFFF"
            android:scaleType="fitCenter"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ui_settings" />

        <LinearLayout
            android:id="@+id/dialogs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="128dp"
            android:layout_marginEnd="128dp"
            android:layout_marginBottom="64dp"
            android:orientation="vertical"
            android:paddingTop="64dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <RelativeLayout
                android:id="@+id/trial_on_pause"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:foregroundGravity="fill_horizontal|fill"
                android:maxWidth="600dp"
                android:maxHeight="800dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/background1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    app:srcCompat="@drawable/ui_properties_window" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/body1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/contents1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="32dp"
                        android:layout_marginEnd="32dp"
                        android:gravity="right"
                        android:orientation="vertical"
                        android:padding="16dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0.533">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="32dp"
                            android:layout_marginEnd="12dp"
                            android:fitsSystemWindows="true"
                            android:gravity="center"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_bias="1.0">

                            <!-- Status text at the top -->

                            <!-- Main menu buttons in the center -->

                            <ImageView
                                android:id="@+id/title1"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:layout_marginStart="124dp"
                                android:layout_marginEnd="124dp"
                                android:scaleType="centerInside"
                                app:srcCompat="@drawable/title_trial_on_pause" />

                            <LinearLayout
                                android:id="@+id/buttons1"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginStart="64dp"
                                android:layout_marginEnd="64dp"
                                android:layout_marginBottom="64dp"
                                android:gravity="center"
                                android:orientation="horizontal">

                                <ImageButton
                                    android:id="@+id/backButton1"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:background="#00FFFFFF"
                                    android:scaleType="centerInside"
                                    app:srcCompat="@drawable/ui_back" />

                                <ImageButton
                                    android:id="@+id/playButton1"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="3"
                                    android:background="#00FFFFFF"
                                    android:scaleType="centerInside"
                                    app:srcCompat="@drawable/ui_play" />

                                <ImageButton
                                    android:id="@+id/retryButton1"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:background="#00FFFFFF"
                                    android:scaleType="centerInside"
                                    app:srcCompat="@drawable/ui_retry" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/trial_fail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:foregroundGravity="fill_horizontal|fill"
                android:maxWidth="600dp"
                android:maxHeight="800dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/background2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    app:srcCompat="@drawable/ui_properties_window" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/body2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/contents2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="32dp"
                        android:layout_marginEnd="32dp"
                        android:gravity="right"
                        android:orientation="vertical"
                        android:padding="16dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0.533">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="32dp"
                            android:layout_marginEnd="12dp"
                            android:fitsSystemWindows="true"
                            android:gravity="center"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_bias="1.0">

                            <!-- Status text at the top -->

                            <!-- Main menu buttons in the center -->

                            <ImageView
                                android:id="@+id/title2"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:layout_marginStart="124dp"
                                android:layout_marginEnd="124dp"
                                android:scaleType="centerInside"
                                app:srcCompat="@drawable/title_trial_fail" />

                            <LinearLayout
                                android:id="@+id/buttons2"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginStart="64dp"
                                android:layout_marginEnd="64dp"
                                android:layout_marginBottom="64dp"
                                android:gravity="center"
                                android:orientation="horizontal">

                                <ImageButton
                                    android:id="@+id/backButton2"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:background="#00FFFFFF"
                                    android:scaleType="centerInside"
                                    app:srcCompat="@drawable/ui_back" />

                                <ImageButton
                                    android:id="@+id/retryButton2"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:background="#00FFFFFF"
                                    android:scaleType="centerInside"
                                    app:srcCompat="@drawable/ui_retry" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/trial_complete"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:foregroundGravity="fill_horizontal|fill"
                android:maxWidth="600dp"
                android:maxHeight="800dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/background3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    app:srcCompat="@drawable/ui_properties_window" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/body3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/contents3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="32dp"
                        android:layout_marginEnd="32dp"
                        android:gravity="right"
                        android:orientation="vertical"
                        android:padding="16dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0.533">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="12dp"
                            android:layout_marginTop="32dp"
                            android:layout_marginEnd="12dp"
                            android:fitsSystemWindows="true"
                            android:gravity="center"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_bias="1.0">

                            <!-- Status text at the top -->

                            <!-- Main menu buttons in the center -->

                            <ImageView
                                android:id="@+id/title3"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:layout_marginStart="124dp"
                                android:layout_marginEnd="124dp"
                                android:layout_weight="1"
                                android:scaleType="centerInside"
                                app:srcCompat="@drawable/title_trial_complete" />

                            <TextView
                                android:id="@+id/timeText3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/aclonica"
                                android:text="TIME: --:--"
                                android:textAlignment="center"
                                android:textColor="#875120"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:typeface="sans" />

                            <LinearLayout
                                android:id="@+id/starsLayout"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_marginStart="64dp"
                                android:layout_marginEnd="64dp"
                                android:layout_marginBottom="32dp"
                                android:layout_weight="5"
                                android:gravity="center"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/star1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    app:srcCompat="@drawable/ui_star" />

                                <ImageView
                                    android:id="@+id/star2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    app:srcCompat="@drawable/ui_star_empty" />

                                <ImageView
                                    android:id="@+id/star3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    app:srcCompat="@drawable/ui_star_empty" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/privateLevelVerifiedMessageText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/aclonica"
                                android:text="Level Verified! Now you can publish your level with your current time score."
                                android:textAlignment="center"
                                android:textColor="#875120"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:typeface="sans"
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/buttons3"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <ImageButton
                            android:id="@+id/backButton3"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="#00FFFFFF"
                            android:scaleType="fitStart"
                            app:srcCompat="@drawable/ui_back" />

                        <ImageButton
                            android:id="@+id/retryButton3"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="#00FFFFFF"
                            android:scaleType="fitEnd"
                            app:srcCompat="@drawable/ui_retry" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </RelativeLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>